{
  "name": "saucedemo-playwright-framework",
  "version": "1.0.0",
  "description": "Enterprise-grade Playwright TypeScript automation framework for SauceDemo",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:chrome": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "report": "playwright show-report reports/html",
    "report:open": "playwright show-report reports/html",
    "lint": "eslint src tests --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf reports test-results"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.1",
    "@types/node": "^22.15.34",
    "typescript": "^5.8.3",
    "eslint": "^9.30.0",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "rimraf": "^6.0.1"
  },
  "dependencies": {
    "dotenv": "^16.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
